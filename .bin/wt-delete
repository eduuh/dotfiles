#!/bin/bash

# Delete a worktree
# Usage: wt-delete <folder-name> [--force]

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    echo -e "${BLUE}Usage:${NC} wt-delete <folder-name> [--force]"
    echo ""
    echo -e "${BLUE}Options:${NC}"
    echo "  --force    Force delete even with uncommitted changes"
    echo ""
    echo -e "${BLUE}List worktrees:${NC}"
    echo "  wt-list"
    exit 1
}

# Find project root
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.bare" ]; then
            echo "$dir"
            return 0
        fi
        if [ -f "$dir/.git" ]; then
            local gitdir=$(cat "$dir/.git" | sed 's/gitdir: //')
            local bare_dir=$(dirname $(dirname "$gitdir"))
            if [ -d "$bare_dir" ] && [ "$(basename $bare_dir)" = ".bare" ]; then
                echo "$(dirname $bare_dir)"
                return 0
            fi
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

PROJECT_ROOT=$(find_project_root)
if [ -z "$PROJECT_ROOT" ]; then
    echo -e "${RED}Error:${NC} Not in a bare repo worktree project"
    exit 1
fi

BARE_DIR="$PROJECT_ROOT/.bare"

if [ -z "$1" ]; then
    usage
fi

FOLDER_NAME="$1"
FORCE=""

if [ "$2" == "--force" ]; then
    FORCE="--force"
fi

# Protect main worktree
if [ "$FOLDER_NAME" == "main" ]; then
    echo -e "${RED}Error:${NC} Cannot delete the main worktree"
    exit 1
fi

WORKTREE_PATH="$PROJECT_ROOT/$FOLDER_NAME"

# Check if worktree exists
if [ ! -d "$WORKTREE_PATH" ]; then
    echo -e "${RED}Error:${NC} Worktree not found at $WORKTREE_PATH"
    echo ""
    echo -e "${BLUE}Available worktrees:${NC}"
    git -C "$BARE_DIR" worktree list
    exit 1
fi

# Get branch name for this worktree
cd "$BARE_DIR"
BRANCH_NAME=$(git worktree list --porcelain | grep -A2 "worktree $WORKTREE_PATH" | grep "branch" | sed 's/branch refs\/heads\///')

echo -e "${YELLOW}Removing worktree...${NC}"
echo "  Path: $WORKTREE_PATH"
echo "  Branch: $BRANCH_NAME"
echo ""

# Confirm if not forced
if [ -z "$FORCE" ]; then
    read -p "Are you sure? This will delete the local branch. (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}Cancelled.${NC}"
        exit 0
    fi
fi

# Remove worktree
git worktree remove "$WORKTREE_PATH" $FORCE

# Delete local branch if it still exists
if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo -e "${YELLOW}Deleting local branch $BRANCH_NAME...${NC}"
    git branch -D "$BRANCH_NAME" 2>/dev/null || true
fi

echo ""
echo -e "${GREEN}✓ Worktree removed!${NC}"
