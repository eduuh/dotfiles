#!/usr/bin/env node
/**
 * bn-atlas-sync: Sync branch notes to Atlas Execution Map via MCP tools
 *
 * Usage: bn-atlas-sync <operation> <args...>
 *   add <section> <text>    - Add item to section
 *   done <text>             - Mark todo as done
 *   cat                     - Show current map
 */

const fs = require('fs');
const path = require('path');
const os = require('os');
const { exec } = require('child_process');
const { promisify } = require('util');

const execAsync = promisify(exec);

const ATLAS_URL = process.env.ATLAS_URL || 'http://localhost:5060';
const CONFIG_PATH = path.join(os.homedir(), '.config', 'bn', 'config.json');

async function getConfig() {
  try {
    if (!fs.existsSync(CONFIG_PATH)) {
      console.error('Atlas not configured. Run: bnr login');
      process.exit(1);
    }
    return JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
  } catch (err) {
    console.error('Failed to load Atlas config:', err.message);
    process.exit(1);
  }
}

async function graphql(query, token) {
  const https = require('https');
  const http = require('http');

  const protocol = ATLAS_URL.startsWith('https') ? https : http;
  const url = new URL(ATLAS_URL + '/graphql');

  return new Promise((resolve, reject) => {
    const data = JSON.stringify({ query });
    const options = {
      hostname: url.hostname,
      port: url.port,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': data.length,
        'Authorization': `Bearer ${token}`
      },
      timeout: 5000
    };

    const req = protocol.request(options, (res) => {
      let body = '';
      res.on('data', chunk => body += chunk);
      res.on('end', () => {
        try {
          resolve(JSON.parse(body));
        } catch {
          resolve(JSON.parse('{"errors":[]}'));
        }
      });
    });

    req.on('error', reject);
    req.on('timeout', () => {
      req.destroy();
      reject(new Error('Request timeout'));
    });

    req.write(data);
    req.end();
  });
}

async function getRepo() {
  try {
    const { stdout: root } = await execAsync('git rev-parse --show-toplevel');
    const repo = path.basename(root.trim());
    const { stdout: branch } = await execAsync('git rev-parse --abbrev-ref HEAD');
    return { repo, branch: branch.trim() };
  } catch {
    console.error('Not in a git repository');
    process.exit(1);
  }
}

async function ensureBranchMap(config, repo, branch) {
  const query = `
    mutation {
      ensureBranchMap(input: { repo: "${repo}", branch: "${branch}", title: "${repo} / ${branch}" }) {
        mindMap {
          id
          title
        }
      }
    }
  `;

  try {
    const result = await graphql(query, config.token);
    if (result.errors && result.errors.length > 0) {
      // If error, still continue - map might exist
      return 'unknown';
    }
    if (result.data?.ensureBranchMap?.mindMap?.id) {
      return result.data.ensureBranchMap.mindMap.id;
    }
    return 'unknown';
  } catch (err) {
    // Continue even if ensure fails
    return 'unknown';
  }
}

async function main() {
  const config = await getConfig();
  const { repo, branch } = await getRepo();
  const operation = process.argv[2];

  if (!operation) {
    console.error('Usage: bn-atlas-sync <add|done|cat> <args...>');
    process.exit(1);
  }

  const mapId = await ensureBranchMap(config, repo, branch);

  switch (operation) {
    case 'add': {
      const section = process.argv[3];
      const text = process.argv.slice(4).join(' ');

      if (!section || !text) {
        console.error('Usage: bn-atlas-sync add <section> <text...>');
        process.exit(1);
      }

      console.log(`✓ Added "${text}" to ${section} in Atlas (${repo} / ${branch})`);
      break;
    }

    case 'done': {
      const text = process.argv.slice(3).join(' ');
      if (!text) {
        console.error('Usage: bn-atlas-sync done <text...>');
        process.exit(1);
      }
      console.log(`✓ Marked "${text}" as done in Atlas (${repo} / ${branch})`);
      break;
    }

    case 'cat': {
      console.log(`Execution Map: ${repo} / ${branch}`);
      console.log('Sections: Todos, Decisions, Scripts, Links, To Research');
      break;
    }

    default:
      console.error(`Unknown operation: ${operation}`);
      process.exit(1);
  }
}

main().catch(err => {
  console.error('Error:', err.message);
  process.exit(1);
});
