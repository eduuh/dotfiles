#!/bin/bash

# Create a new worktree with auto-setup
# Usage: wt-new <type>/<branch-name> [base-branch]
# Works with any bare repo setup (detects project root automatically)

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    echo -e "${BLUE}Usage:${NC} wt-new <type>/<branch-name> [base-branch]"
    echo ""
    echo -e "${BLUE}Types:${NC}"
    echo "  feat/   - New features"
    echo "  fix/    - Bug fixes"
    echo "  chore/  - Maintenance tasks"
    echo "  refactor/ - Code refactoring"
    echo "  docs/   - Documentation"
    echo "  test/   - Testing"
    echo ""
    echo -e "${BLUE}Examples:${NC}"
    echo "  wt-new feat/user-auth"
    echo "  wt-new fix/api-timeout main"
    exit 1
}

# Find project root (parent of .bare directory)
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.bare" ]; then
            echo "$dir"
            return 0
        fi
        # Check if we're in a worktree
        if [ -f "$dir/.git" ]; then
            local gitdir=$(cat "$dir/.git" | sed 's/gitdir: //')
            local bare_dir=$(dirname $(dirname "$gitdir"))
            if [ -d "$bare_dir" ] && [ "$(basename $bare_dir)" = ".bare" ]; then
                echo "$(dirname $bare_dir)"
                return 0
            fi
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

PROJECT_ROOT=$(find_project_root)
if [ -z "$PROJECT_ROOT" ]; then
    echo -e "${RED}Error:${NC} Not in a bare repo worktree project"
    echo "Run this from within a project that uses the bare repo worktree setup"
    exit 1
fi

BARE_DIR="$PROJECT_ROOT/.bare"

# Validate arguments
if [ -z "$1" ]; then
    usage
fi

BRANCH_NAME="$1"
BASE_BRANCH="${2:-main}"

# Validate branch name format
if [[ ! "$BRANCH_NAME" =~ ^(feat|fix|chore|refactor|docs|test)/ ]]; then
    echo -e "${RED}Error:${NC} Branch name must start with feat/, fix/, chore/, refactor/, docs/, or test/"
    usage
fi

# Extract folder name (e.g., feat/add-auth -> feat-add-auth)
FOLDER_NAME=$(echo "$BRANCH_NAME" | tr '/' '-')
WORKTREE_PATH="$PROJECT_ROOT/$FOLDER_NAME"

# Check if worktree already exists
if [ -d "$WORKTREE_PATH" ]; then
    echo -e "${RED}Error:${NC} Worktree already exists at $WORKTREE_PATH"
    exit 1
fi

echo -e "${BLUE}Creating worktree...${NC}"
echo "  Project: $(basename $PROJECT_ROOT)"
echo "  Branch: $BRANCH_NAME"
echo "  Base: $BASE_BRANCH"
echo "  Path: $WORKTREE_PATH"
echo ""

# Fetch latest
echo -e "${YELLOW}Fetching latest from origin...${NC}"
cd "$BARE_DIR"
git fetch origin --prune

# Check if branch exists remotely
if git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME"; then
    echo -e "${YELLOW}Branch exists on remote, checking it out...${NC}"
    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
else
    # Create new branch from base
    echo -e "${YELLOW}Creating new branch from $BASE_BRANCH...${NC}"
    git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/$BASE_BRANCH"
fi

echo ""
echo -e "${GREEN}✓ Worktree created!${NC}"
echo ""

# Run setup if it exists
if [ -f "$WORKTREE_PATH/scripts/wt-setup.sh" ]; then
    echo -e "${YELLOW}Running project setup...${NC}"
    cd "$WORKTREE_PATH"
    bash scripts/wt-setup.sh
elif [ -f "$WORKTREE_PATH/package.json" ]; then
    echo -e "${YELLOW}Installing npm dependencies...${NC}"
    cd "$WORKTREE_PATH"
    npm install
fi

# Setup hooks if setup script exists
if [ -f "$WORKTREE_PATH/scripts/setup-hooks.sh" ]; then
    bash "$WORKTREE_PATH/scripts/setup-hooks.sh"
fi

echo ""
echo -e "${GREEN}✓ Done!${NC}"
echo ""
echo -e "${BLUE}To start working:${NC}"
echo "  cd $WORKTREE_PATH"
echo ""
