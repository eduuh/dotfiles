#!/usr/bin/env zsh
# tat - Tmux Attach to project
# Simple session manager with zoxide frecency + fzf preview

source "$HOME/.bin/tmux/tmux-lib.sh"

require_tmux
tmux_init
require_fzf

PREVIEW_SCRIPT="$HOME/.bin/tmux/tat-preview.sh"
TEMPLATE_SCRIPT="$HOME/.bin/tmux/tat-template.sh"

# Get all projects: bare repos + regular clones (bare wins on name collision)
get_projects() {
    local -A seen
    local projects=()

    # Bare repos first (they take priority over regular clones)
    if [[ -d "$BARE_DIR" ]]; then
        for bare in "$BARE_DIR"/*.git(N/); do
            local name=$(basename "$bare" .git)
            seen[$name]=1
            projects+=("$name")
        done
    fi

    # Regular clones: must be a git repo, skip if already listed as bare repo
    for dir in "$PROJECT_ROOT"/*/(N); do
        [[ -d "$dir" ]] || continue
        local name=$(basename "$dir")
        [[ "$name" == .* || "$name" == "bare" || "$name" == "worktree" ]] && continue
        (( ${+seen[$name]} )) && continue
        [[ -d "$dir/.git" || -f "$dir/.git" ]] || continue
        projects+=("$name")
    done

    printf '%s\n' "${projects[@]}"
}

# Sort projects by zoxide frecency
sort_by_frecency() {
    if command -v zoxide &>/dev/null; then
        while IFS= read -r project; do
            if is_bare_repo "$project"; then
                ppath=$(bare_repo_main_path "$project")
            else
                ppath=$(resolve_project_path "$project")
            fi
            score=$(zoxide query -s "$ppath" 2>/dev/null | /usr/bin/awk '{print $1}')
            [[ -z "$score" ]] && score="0"
            echo "$score $project"
        done | sort -rn | /usr/bin/awk '{print $2}'
    else
        sort
    fi
}

# Check if session exists
has_session() {
    $TMUX_CMD has-session -t "=$1" 2>/dev/null
}

# Build display list with session indicators and window count
build_list() {
    get_projects | sort_by_frecency | while IFS= read -r project; do
        if has_session "$project"; then
            local wc=$(session_window_count "$project")
            echo "[*${wc}w] $project"
        else
            echo "      $project"
        fi
    done
}

# --list mode: output the list and exit (used by fzf reload)
if [[ "$1" == "--list" ]]; then
    build_list
    exit 0
fi

# Kill helper for fzf execute binding
KILL_SCRIPT=$(mktemp)
trap 'rm -f "$KILL_SCRIPT"' EXIT INT TERM
cat > "$KILL_SCRIPT" << 'KILLEOF'
#!/usr/bin/env zsh
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
project="${@##* }"  # last word = project name
current=$(tmux display-message -p '#S' 2>/dev/null)
[[ "$project" == "$current" ]] && exit 0  # don't kill current session
tmux has-session -t "=$project" 2>/dev/null && tmux kill-session -t "=$project"
KILLEOF
chmod +x "$KILL_SCRIPT"

# Run fzf with preview; --print-query lets us catch 'repo/branch' typed for a new worktree
result=$(build_list | "$FZF_CMD" \
    --reverse \
    --ansi \
    --print-query \
    --header="Enter: open | ctrl-x: kill | type 'repo/branch' to create worktree" \
    --preview="$PREVIEW_SCRIPT {-1}" \
    --preview-window="right:50%:wrap" \
    --bind="ctrl-x:execute-silent($KILL_SCRIPT {})+reload($0 --list)")
fzf_exit=$?

[[ $fzf_exit -eq 130 ]] && exit 0

query=$(echo "$result" | sed -n '1p')
selected_line=$(echo "$result" | sed -n '2p')

# Typed 'repo/branch' with no matching row → create worktree from latest main
if [[ -z "$selected_line" && "$query" == */* ]]; then
    repo="${query%%/*}"
    branch="${query#*/}"
    if ! is_bare_repo "$repo"; then
        echo "Not a bare repo: $repo"
        read -sk1 "?Press any key..."
        exit 1
    fi
    if ! ensure_worktree "$repo" "$branch"; then
        read -sk1 "?Press any key..."
        exit 1
    fi
    sanitized="${branch//\//-}"
    worktree_path="$WORKTREE_DIR/$repo/$sanitized"
    session_name="$repo"

    if ! has_session "$session_name"; then
        "$TEMPLATE_SCRIPT" "$session_name" "$(bare_repo_main_path "$repo")"
    fi

    if $TMUX_CMD list-windows -t "=$session_name" -F '#{window_name}' 2>/dev/null | grep -qxF "$sanitized"; then
        $TMUX_CMD select-window -t "${session_name}:${sanitized}"
    else
        $TMUX_CMD new-window -t "$session_name" -n "$sanitized" -c "$worktree_path"
    fi
    $TMUX_CMD switch-client -t "$session_name"
    exit 0
fi

selected=$(echo "$selected_line" | /usr/bin/awk '{print $NF}')
[[ -z "$selected" ]] && exit 0

session_name="$selected"
if is_bare_repo "$selected"; then
    project_path=$(bare_repo_main_path "$selected")
else
    project_path=$(resolve_project_path "$selected")
fi

# Create or switch to session
if has_session "$session_name"; then
    # Open windows in this session
    open_windows=(${(f)"$($TMUX_CMD list-windows -t "=$session_name" -F '#{window_name}' 2>/dev/null)"})

    # Worktrees for bare repos; empty for plain clones
    worktrees=()
    if is_bare_repo "$session_name"; then
        worktrees=(${(f)"$(list_worktrees "$session_name")"})
    fi

    # Orphan worktrees: on disk but no window open for them
    orphans=()
    for wt in "${worktrees[@]}"; do
        [[ -z "$wt" ]] && continue
        found=0
        for ow in "${open_windows[@]}"; do
            [[ "$ow" == "$wt" ]] && { found=1; break }
        done
        (( found )) || orphans+=("$wt")
    done

    # Nothing to pick: single window and no orphans → just switch
    if (( ${#open_windows[@]} <= 1 && ${#orphans[@]} == 0 )); then
        $TMUX_CMD switch-client -t "$session_name"
        exit 0
    fi

    # Build picker rows: kind|payload|display
    rows=""
    while IFS='|' read -r idx name cmd wpath active; do
        [[ -z "$idx" ]] && continue
        short="${wpath/#$HOME/~}"
        marker=""
        [[ "$active" == "1" ]] && marker="*"
        display=$(printf "%s%s: %-14s %-8s %s" "$idx" "$marker" "$name" "$cmd" "$short")
        rows+="window|$idx|$display"$'\n'
    done < <($TMUX_CMD list-windows -t "=$session_name" \
        -F "#{window_index}|#{window_name}|#{pane_current_command}|#{pane_current_path}|#{window_active}" 2>/dev/null)

    for wt in "${orphans[@]}"; do
        short="~/projects/worktree/$session_name/$wt"
        display=$(printf " +: %-14s %-8s %s" "$wt" "(worktree)" "$short")
        rows+="worktree|$wt|$display"$'\n'
    done

    selection=$(printf '%s' "$rows" | "$FZF_CMD" \
        --reverse \
        --delimiter="|" \
        --with-nth=3 \
        --header="Pick window/worktree (Esc: current)")

    if [[ -z "$selection" ]]; then
        $TMUX_CMD switch-client -t "$session_name"
        exit 0
    fi

    kind="${selection%%|*}"
    rest="${selection#*|}"
    payload="${rest%%|*}"

    if [[ "$kind" == "window" ]]; then
        $TMUX_CMD switch-client -t "$session_name:$payload"
    else
        wt_path="$WORKTREE_DIR/$session_name/$payload"
        $TMUX_CMD new-window -t "$session_name" -n "$payload" -c "$wt_path"
        $TMUX_CMD switch-client -t "$session_name"
    fi
else
    "$TEMPLATE_SCRIPT" "$session_name" "$project_path"
fi
