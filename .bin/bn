# See note.md for Goal/Progress prose.
repo: $repo
branch: $branch
created: $date
status: active
machine: $machine
type: null
work_item: null
pr: null
tags: []
collaborators: []

todos: []
blockers: []
decisions: []
research: []
collab: []
ask: []
EOF
}

