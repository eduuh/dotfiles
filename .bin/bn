# Run a named script (default: build)
cmd_build() {
    local name="${1:-build}"
    require_git_context
    ensure_scripts_dir "$NOTE_REPO"

    local script
    resolve_script "$NOTE_REPO" "$name"; script=$REPLY
    if [[ ! -f "$script" ]]; then
        echo "No script '$name' for $NOTE_REPO" >&2
